# Firebase Functions Environment Variables for Local Development
# Copy this file to functions/.env.local for local development

# Google Generative AI (Gemini) API Key
# Get this from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Project Configuration
# NOTE: FIREBASE_PROJECT_ID, FIREBASE_CONFIG etc. are reserved — Firebase injects them
# automatically. Do NOT set them here or in functions/.env.
# FIREBASE_PROJECT_ID=study-forge-ai  <-- reserved, do not set

# Storage bucket - must match inject-perfect-document.ts for E2E tests.
# EMULATOR: use .appspot.com — the Storage emulator treats these as different buckets.
# PRODUCTION: use .firebasestorage.app (the project's actual default bucket).
#   In production, getBucket() prefers FIREBASE_CONFIG.storageBucket (auto-injected by
#   Firebase at runtime) over this var, so the value here only matters for the emulator.
STORAGE_BUCKET=study-forge-ai.appspot.com

# Development Environment
NODE_ENV=development

# Enable debug logging
DEBUG=true