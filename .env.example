# NX Workspace Environment Variables Example
# Copy this to .env and fill in your actual values

# Server-side Environment Variables (Node.js/Functions - NX_ prefix)
NX_FIREBASE_REGION=asia-east1
NX_ENVIRONMENT=production

# Public Environment Variables (Client-side accessible - NX_PUBLIC_ prefix)
NX_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NX_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NX_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NX_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NX_PUBLIC_FIREBASE_APP_ID=your-app-id

# Web/React Environment Variables (NX_PUBLIC_ prefix for Vite-specific client-side)
NX_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NX_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NX_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NX_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NX_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NX_PUBLIC_FIREBASE_APP_ID=your-app-id

# Gemini API key (client-side; also set as a GitHub Actions secret for production builds)
NX_PUBLIC_GEMINI_API_KEY=your-gemini-api-key-here

# App Check (reCAPTCHA v3) - required for emulator when using App Check. Create a v3 key in reCAPTCHA Admin Console.
# NX_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=your-recaptcha-v3-site-key